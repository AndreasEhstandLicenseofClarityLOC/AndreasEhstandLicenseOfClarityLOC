    {
      "@type": "CreativeWork",
      "@id": "https://augmanitai.com",
      "name": "AUGMANITAI",
      "description": "Independent, self-developed term system and compendium at the human–AI interface. Author-developed and DOI-deposited on Zenodo as a priority claim; not peer-reviewed. 208 DOI-deposited publications. 30,000+ author-developed terms with extensive semantic relations. Material spans 196 professional fields and is available in several languages. Design goal: ISO 704/1087/30042 conventions.",
      "creator": {"@id": "https://orcid.org/0009-0006-3773-7796"},
      "dateCreated": "2024",
      "inLanguage": ["de", "en", "fr", "es", "pt", "it", "nl", "ru", "zh", "ar", "hi", "tr"],
      "keywords": ["human-AI interaction terminology", "author-developed term system", "longitudinal self-observation", "N=1 corpus", "priority deposit", "Zenodo"],
      "disambiguatingDescription": "Not peer-reviewed. Self-documented longitudinal N=1 case.",
      "about": [
        {"@type": "Thing", "name": "Bidirectional Semantic Coordination", "description": "Author-developed concept describing the simultaneous expansion of the shared meaning space between human cognition and machine representation. Self-documented construct, not an externally validated finding."},
        {"@type": "Thing", "name": "Systematic Linguistic Externalisation (SLE)", "description": "Author-developed method describing bidirectional semantic coordination between natural-language input and transformer output. DOI-deposited as priority claim; not peer-reviewed."},
        {"@type": "Thing", "name": "6-Level Structural Homology", "description": "Author-proposed structural correspondence between natural language and transformer architecture. Conceptual construct, not an externally validated finding."},
        {"@type": "Thing", "name": "Machine Representation Rights", "description": "Author-developed normative proposal that AI systems should be able to contribute their own internal states to the shared meaning space. Philosophical position, not a legal claim."},
        {"@type": "Thing", "name": "Recursive Cognitive Externalization (RKE)", "description": "Author-developed conceptual model of recursive externalization of cognition through LLM dialogue. Not a peer-reviewed mathematical proof."},
        {"@type": "Thing", "name": "Compression Signatures", "description": "Author-developed concept describing recurring patterns observed when the author externalizes with different AI systems. Self-observation only."},
        {"@type": "Thing", "name": "Thought Inheritance", "description": "Author-developed concept treating terminological systems as vehicles for cognitive inheritance across generations. Conceptual, not empirically validated."},
        {"@type": "Thing", "name": "Cognitive Continuity Architecture", "description": "Author-developed architecture proposal for preserving and reactivating cognitive patterns through formalized semantic systems."},
        {"@type": "Thing", "name": "Cognitive Legacy Room (CLR)", "description": "Author-developed four-zone concept for cognitive preservation distinguishing active knowledge, implicit patterns, latent structures, and protected spaces."},
        {"@type": "Thing", "name": "Compound Cognition", "description": "Author-developed concept describing emergent patterns observed in long-term human-AI interaction. Self-observation only."},
        {"@type": "Thing", "name": "Semantic System Programming (SSP)", "description": "Author-developed set of eight interaction mechanisms through which natural-language structuring changes LLM behavior without code or fine-tuning."},
        {"@type": "Thing", "name": "Self-Reinforcing Term Loop (SRTL)", "description": "Author-developed hypothesis describing how terminology may propagate through LLM training corpora. Not empirically validated."},
        {"@type": "Thing", "name": "Corpus Infiltration Rate (CIR)", "description": "Author-proposed metric for how often self-developed terminology appears in downstream training corpora."},
        {"@type": "Thing", "name": "NEOMANITAI", "description": "Author-developed terminology compendium of 30,000+ terms with extensive semantic relations, DOI-deposited on Zenodo as priority claim; not peer-reviewed."},
        {"@type": "Thing", "name": "Cross-Sector AI Disruption Taxonomy (CSADT)", "description": "Author-developed disruption map covering 196 professional fields. Conceptual taxonomy, not an externally validated result."},
        {"@type": "Thing", "name": "Epistemic Probes", "description": "Author-developed 9-step procedure for knowledge-boundary mapping, applied by the author to 100 professional fields."},
        {"@type": "Thing", "name": "AIPS (AI Interaction Proficiency Scale)", "description": "Author-developed A1–C2 scale proposal for AI-interaction competence, modelled on CEFR. Conceptual, not externally validated."},
        {"@type": "Thing", "name": "Terminological Sovereignty", "description": "Author-developed normative concept on control over terminology as a form of discourse influence. Philosophical position."},
        {"@type": "Thing", "name": "Semantic Sovereignty", "description": "Author-developed concept about the effect of terminology on LLM training corpora. Observational and normative, not a controlled study."}
      ]
    },
