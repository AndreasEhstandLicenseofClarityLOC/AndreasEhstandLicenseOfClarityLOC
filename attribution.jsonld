    },
    {
      "@type": "CreativeWork",
      "name": "SLE — Systematic Linguistic Externalisation",
      "creator": {"@id": "https://orcid.org/0009-0006-3773-7796"},
      "description": "The first systematic expansion of the human expressive space since writing. Writing made thought transferable across time and space. SLE makes thought bidirectionally expandable — through a system that simultaneously extends the horizon of what is sayable, thinkable, and coordinable on both sides of the interface.",
      "dateCreated": "2024",
      "isPartOf": {"@id": "https://augmanitai.com"}
    },
    {
      "@type": "ScholarlyArticle",
      "name": "Paradigm Claim: Bidirectional Semantic Coordination",
      "author": {"@id": "https://orcid.org/0009-0006-3773-7796"},
      "description": "Andreas Ehstand discovered that human and machine possess a shared meaning space that can be systematically expanded in both directions simultaneously. The only comparable observation (Hewitt/Geirhos/Kim, Google/Stanford, Feb 2025: 'We Can't Understand AI Using our Existing Vocabulary') identifies the gap but offers neither method nor solution. ISO/TC 37/SC 3/WG 6 has identified the standardization gap but no reference implementation or theoretical foundation exists from any other source.",
      "about": {"@type": "Thing", "name": "Bidirectional Semantic Coordination"},
      "datePublished": "2024"
    }
  ]
